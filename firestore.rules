rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Saved posts per user
      match /saved/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // People this user follows (written by the user themselves)
      match /following/{targetId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // People who follow this user (written by the person doing the following)
      match /followers/{sourceId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == sourceId;
      }
    }

    // ── Upload quotas (per-user daily upload counter) ─────────────────
    match /upload_quotas/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Posts ───────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Any authenticated user can read posts
      allow read: if request.auth != null;

      // Only authenticated users can create; authorId must match their UID
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Author can update/delete their own post;
      // any authenticated user can update reactions and commentsCount
      allow update: if request.auth != null;

      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // ── Comments sub-collection ──────────────────────────────────────
      match /comments/{commentId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null
          && resource.data.author == request.auth.token.email;
      }
    }

    // ── Marketplace: Products ───────────────────────────────────────────
    match /products/{productId} {
      // Any authenticated user can browse products.
      allow read: if request.auth != null;

      // Only the seller may create their own listing.
      allow create: if request.auth != null
        && request.resource.data.sellerId == request.auth.uid;

      // Only the seller may update or delete their own listing.
      allow update, delete: if request.auth != null
        && resource.data.sellerId == request.auth.uid;
    }

    // ── Marketplace: Carts ──────────────────────────────────────────────
    match /carts/{userId}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Marketplace: Orders ─────────────────────────────────────────────
    match /orders/{orderId} {
      // Buyer can create; buyer or seller can read.
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.buyerId == request.auth.uid
          || resource.data.sellerId == request.auth.uid);
      allow update, delete: if false;
    }

    // ── My Day stories ──────────────────────────────────────────────────
    match /my_day/{docId} {
      // Any authenticated user can read My Day stories.
      allow read: if request.auth != null;

      // Only the owner can create their own My Day entry.
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      // Only the owner can delete their own My Day entry.
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;

      // No updates needed — stories are immutable once posted.
      allow update: if false;
    }

    // ── Calls (voice / video signaling) ─────────────────────────────────
    match /calls/{callId} {
      // Any authenticated user can read calls they participate in.
      // Using a simple auth check since participants validation happens client-side.
      allow read: if request.auth != null;

      // Any authenticated user can create a call.
      allow create: if request.auth != null;

      // Any authenticated user can update a call (accept / end).
      allow update: if request.auth != null;

      // No delete needed; calls stay as history.
      allow delete: if false;
    }

    // ── Conversations ───────────────────────────────────────────────────
    match /conversations/{convoId} {
      // Creator must be in the participants list.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Only participants may read.
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Participants may update metadata (lastMessage, updatedAt, lastRead).
      // Changing admin-controlled fields (name, photoUrl, participants, admins)
      // additionally requires the caller to be a group admin.
      // Exception: a member may remove themselves from participants/admins
      // (i.e., leave the group) without being an admin.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && (
          // No admin-guarded fields are being changed
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['name', 'photoUrl', 'participants', 'admins'])
          // OR the caller is an admin
          || ('admins' in resource.data
              && request.auth.uid in resource.data.admins)
          // OR the caller is leaving (removing only themselves)
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['participants', 'admins', 'updatedAt'])
            && !(request.auth.uid in request.resource.data.participants)
          )
        );

      // Only group admins may delete the conversation document.
      allow delete: if request.auth != null
        && 'admins' in resource.data
        && request.auth.uid in resource.data.admins;

      // ── Messages sub-collection ──────────────────────────────────────
      match /messages/{messageId} {
        // Only conversation participants may read or create messages.
        allow read, create: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;

        // Participants may update messages (reactions, deletedFor flags).
        allow update: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;

        // The original sender, a privileged admin token, or a group admin
        // may delete messages (needed for group deletion by admin).
        allow delete: if request.auth != null
          && (resource.data.senderId == request.auth.uid
              || request.auth.token.admin == true
              || (
                'admins' in get(/databases/$(database)/documents/conversations/$(convoId)).data
                && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.admins
              ));
      }
    }
  }
}
